# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Kafka (2 brokers)
SPRING_KAFKA_BOOTSTRAP_SERVERS=10.0.0.1:9092,10.0.0.2:9092

# Database (RDS)
SPRING_DATASOURCE_URL=jdbc:postgresql://mydb.xxxxxx.rds.amazonaws.com:5432/chat
SPRING_DATASOURCE_USERNAME=youruser
SPRING_DATASOURCE_PASSWORD=yourpassword

# Redis (ElastiCache)
SPRING_REDIS_HOST=mycache.xxxxxx.cache.amazonaws.com
SPRING_REDIS_PORT=6379

# JVM tuning (optional but good)
JAVA_OPTS=-Xms512m -Xmx1024m